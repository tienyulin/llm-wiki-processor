# wiki-processor configuration. Copy to .env and fill in.
# Only this service's variables — see the platform repo for the full stack.

# -- LLM (extraction) ---------------------------------------------------------
LLM_PROVIDER=minimax              # minimax | openai | anthropic | gemini | groq | azure | openai-compatible
LLM_API_KEY=                      # provider API key (MINIMAX_API_KEY also accepted)
LLM_MODEL=MiniMax-M2.7
# LLM_BASE_URL=                   # only for openai-compatible (Ollama/vLLM/LM Studio)
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4000
MOCK_LLM=true                     # true = deterministic mock extraction, no API calls

# -- MinIO (source of truth) --------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=wiki-data

# -- PG + pgvector index (optional; empty = disabled, falls back to MinIO) -----
PG_DSN=postgresql://wiki:wikipass@pg:5432/wiki
EMBEDDING_BASE_URL=               # OpenAI-compatible /v1/embeddings root (empty = mock/relational only)
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_SEND_DIMENSIONS=false   # true for Gemini gemini-embedding-001 (see platform docs/architecture/vector-search.md)
MOCK_EMBEDDINGS=true

# -- Misc ---------------------------------------------------------------------
PROCESSOR_API_KEY=                # empty = unauthenticated /process (dev mode)
MCP_SERVER_URL=                   # optional: mcp-server URL to notify on cache invalidation
