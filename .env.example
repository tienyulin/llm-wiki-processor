# wiki-processor configuration. Copy to .env and fill in.
# Only this service's variables. NOTE: docker compose does NOT strip inline
# "# comments" from .env values — keep comments on their own lines.

# -- LLM (extraction) --
# LLM_PROVIDER: minimax | openai | anthropic | gemini | groq | azure | openai-compatible
LLM_PROVIDER=minimax
# provider API key (MINIMAX_API_KEY also accepted)
LLM_API_KEY=
LLM_MODEL=MiniMax-M2.7
# only for openai-compatible (Ollama/vLLM/LM Studio):
# LLM_BASE_URL=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4000
# true = deterministic mock extraction, no API calls
MOCK_LLM=true

# -- MinIO (shared infra: llm-wiki-infra) --
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=wiki-data

# -- PG + pgvector index (shared infra; empty PG_DSN disables it) --
PG_DSN=postgresql://wiki:wikipass@pg:5432/wiki
# OpenAI-compatible /v1/embeddings root (empty = mock/relational only)
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
# true for Gemini gemini-embedding-001
EMBEDDING_SEND_DIMENSIONS=false
MOCK_EMBEDDINGS=true

# -- Misc --
# empty = unauthenticated /process (dev mode)
PROCESSOR_API_KEY=
# optional: mcp-server URL to notify on cache invalidation
MCP_SERVER_URL=
